<Window x:Class="HistgramApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:l="clr-namespace:HistgramApp"
        xmlns:h="clr-namespace:Maywork.WPF.Helpers"
        mc:Ignorable="d"
        h:WindowCloseHelper.DisposeOnClose="True"
        Title="{Binding Title.Value}" Height="450" Width="800">
        <Window.DataContext>
            <l:MainWindowViewModel/>
        </Window.DataContext>
    <Grid
        h:FileDropHelper.Enable="True"
        h:FileDropHelper.DropCommand="{Binding FileDropCommand}">
        
        <TextBlock
            Text="ここにファイルをドロップ"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>
        
        <!-- ヒストグラム -->
        <Image Source="{Binding HistogramImage.Value}"
               Width="512"
               Height="200"
               HorizontalAlignment="Left"/>
    </Grid>
</Window>
