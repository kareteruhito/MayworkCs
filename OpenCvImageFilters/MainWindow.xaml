<Window x:Class="OpenCvImageFilters.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenCvImageFilters"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">

    <Window.Resources>
        <Style x:Key="GridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#EEE"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="ShowsPreview" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 一番上：高さ5のプログレスバー -->
            <RowDefinition Height="5"/>
            <!-- メニューバー -->
            <RowDefinition Height="Auto"/>
            <!-- アドレスバー -->
            <RowDefinition Height="Auto"/>
            <!-- メイン：2ペイン -->
            <RowDefinition Height="*"/>
            <!-- ステータスバー -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 上部プログレスバー（常時表示の細い帯） -->
        <ProgressBar Grid.Row="0"
                     Minimum="0" Maximum="100" Value="0"
                     Height="1"
                     IsIndeterminate="False"/>

        <!-- メニューバー -->
        <Menu Grid.Row="1">
            <Menu.FontSize>14</Menu.FontSize>
            <MenuItem Header="_ファイル">
                <MenuItem
                    x:Name="MenuItemLoadGrayscale"
                    Header="グレイスケール読み込み"
                    IsCheckable="True"
                    IsChecked="True"/>
                <MenuItem Header="左右連動"
                        x:Name="MenuItemSync"
                        IsCheckable="True"
                        IsChecked="True"
                        Checked="MenuItemSync_Changed"
                        Unchecked="MenuItemSync_Changed"/>
                <Separator/>
                <MenuItem Header="終了" />
            </MenuItem>
            <MenuItem Header="_編集">
                <MenuItem Header="リセット" Click="MenuItemReset_Click"/>
                <MenuItem Header="クリップボードにコピー" Click="MenuItemClipCopy_Click" IsEnabled="{Binding IsFilterApplied}"/>
            </MenuItem>
        </Menu>

        <!-- アドレスバー -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,1">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>     <!-- カレントディレクトリ -->
                </Grid.ColumnDefinitions>

                <!-- カレントディレクトリ -->
                <DockPanel Grid.Column="0" LastChildFill="True">
                    <TextBlock Text="アドレス:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="C:\Users\YourName\Documents"
                             VerticalContentAlignment="Center"
                             Padding="6,3"/>
                </DockPanel>

            </Grid>
        </Border>

        <!-- メイン：2ペイン -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左： -->
                <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                    <ScrollViewer x:Name="ScrollSrc">
                        <Canvas x:Name="CanvasSrc">      
                            <Image x:Name="ImageSrc"/>
                        </Canvas>
                    </ScrollViewer>
                </Border>

                <!-- 仕切り（ドラッグで幅変更） -->
                <GridSplitter Grid.Column="1" Width="5" Style="{StaticResource GridSplitterStyle}" />

                <!-- 右： -->
                <Border Grid.Column="2">
                    <ScrollViewer x:Name="ScrollDst">
                        <Canvas x:Name="CanvasDst">      
                            <Image x:Name="ImageDst"/>
                        </Canvas>
                    </ScrollViewer>
                </Border>
            </Grid>
            <GridSplitter Grid.Row="1" Height="5" Style="{StaticResource GridSplitterStyle}" />
            <Grid Grid.Row="2">
                <TabControl>

                    <TabItem Header="ガウシアンフィルタ">
                        <StackPanel Margin="8">
                            <Button Content="実行" Click="ButtonGaussian_Click" Margin="0,0,0,8" IsEnabled="{Binding IsImageLoaded}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="カーネルサイズ:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="ComboGaussian"
                                        Width="80"
                                        SelectedIndex="1">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="sys:Int32"
                                                xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                            <sys:Int32>3</sys:Int32>
                                            <sys:Int32>5</sys:Int32>
                                            <sys:Int32>7</sys:Int32>
                                            <sys:Int32>9</sys:Int32>
                                            <sys:Int32>11</sys:Int32>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="アンシャープマスクフィルタ">
                        <StackPanel Margin="8">
                            <Button Content="実行" Click="ButtonUnsharp_Click" Margin="0,0,0,8" IsEnabled="{Binding IsImageLoaded}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="カーネルサイズ:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="ComboUnsharpKernel"
                                        Width="80"
                                        SelectedIndex="1">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="sys:Int32"
                                                xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                            <sys:Int32>3</sys:Int32>
                                            <sys:Int32>5</sys:Int32>
                                            <sys:Int32>7</sys:Int32>
                                            <sys:Int32>9</sys:Int32>
                                            <sys:Int32>11</sys:Int32>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="Amount:" Margin="0,0,5,0"/>
                                    <Slider x:Name="SliderUnsharpAmount"
                                            Minimum="0"
                                            Maximum="3"
                                            Value="1"
                                            Width="150"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>


                    <TabItem Header="2値化">
                        <StackPanel Margin="8">
                            <Button Content="実行" Click="ButtonBinary_Click" Margin="0,0,0,8" IsEnabled="{Binding IsImageLoaded}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="閾値:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="SliderBinaryThreshold"
                                        Minimum="0"
                                        Maximum="255"
                                        Value="128"
                                        Width="150"/>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="メディアンフィルタ">
                        <StackPanel Margin="8">
                            <Button Content="実行" Click="ButtonMedian_Click" Margin="0,0,0,8" IsEnabled="{Binding IsImageLoaded}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="ComboMedianKernel"
                                        Width="80"
                                        SelectedIndex="1">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="sys:Int32"
                                                xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                            <sys:Int32>3</sys:Int32>
                                            <sys:Int32>5</sys:Int32>
                                            <sys:Int32>7</sys:Int32>
                                            <sys:Int32>9</sys:Int32>
                                            <sys:Int32>11</sys:Int32>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="ごみ取り"  IsSelected="True">
                        <StackPanel Margin="8">
                            <Button Content="実行" Click="ButtonorphClean_Click" Margin="0,0,0,8" IsEnabled="{Binding IsImageLoaded}"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="縮小">
                        <StackPanel Margin="8">
                            <Button Content="実行" Click="ButtonDownscale_Click" Margin="0,0,0,8" IsEnabled="{Binding IsImageLoaded}"/>
                        </StackPanel>
                    </TabItem>

                </TabControl>
            </Grid>
        </Grid>

        <!-- ステータスバー -->
        <StatusBar Grid.Row="4">
            <StatusBar.FontSize>12</StatusBar.FontSize>
            <StatusBarItem>
                <Button Content="決定" Height="26" Width="50" Click="ButtonCommit_Click" Margin="0,0,0,8" IsEnabled="{Binding IsFilterApplied}"/>
            </StatusBarItem>
            <Separator/>
        </StatusBar>
    </Grid>
</Window>
